# Copy to `.env` for local development (see README). Never commit `.env`.

SECRET_KEY=change-me-for-production
DEBUG=True

# Optional: comma-separated origins for CSRF (needed if DEBUG=False behind HTTPS, or non-default port/host).
# Example: http://127.0.0.1:8001,http://localhost:8001
# CSRF_TRUSTED_ORIGINS=

# Optional: AI-generated video descriptions (Google AI Studio / Gemini API)
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
# Default model name (override if your key does not support this model)
GOOGLE_MODEL_NAME=gemma-3-27b-it

# Optional: course page “Talk to tutor” spoken replies (ElevenLabs text-to-speech only)
# https://elevenlabs.io — create an API key and pick a voice ID from the voice library.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# Solana Devnet — optional “Proof of Skill” badge claims (memo transactions). No API key on Devnet.
# Issuer key: JSON array of 64 bytes (full secret key) from `solana-keygen new` / Phantom export, Devnet only.
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
SOLANA_ISSUER_PRIVATE_KEY=
